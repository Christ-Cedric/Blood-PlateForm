{
  "version": 2,
  "builds": [
    {
      "src": "Blood-Donnation-Platform--main/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/Blood-Donnation-Platform--main/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/Blood-Donnation-Platform--main/dist/index.html"
    }
  ]
}
